# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kiosk_socket

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=24h

# Socket.IO
CORS_ORIGIN=http://localhost:3000
SOCKET_PING_INTERVAL=25000
SOCKET_PING_TIMEOUT=20000

# Seed (mock users)
SEED_KIOSK_EMAIL=cbm_kiosk@qtrust.id
