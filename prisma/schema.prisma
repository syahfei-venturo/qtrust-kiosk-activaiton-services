generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  kiosk
  technician
  admin
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  password  String
  role      Role     @default(kiosk)
  lastLogin DateTime? @map("last_login")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@index([role])
  @@map("users")
}

model HardwareActivation {
  id                String   @id @default(uuid())
  hardwareId        String   @unique @map("hardware_id")
  activationId      String?  @map("activation_id")
  status            String   @default("Pending")
  deviceName        String?  @map("device_name")
  groupName         String?  @map("group_name")
  groupId           Int?     @map("group_id")
  dealerName        String?  @map("dealer_name")
  qrcode            String?
  serialNumber      String?  @map("serial_number")
  loginDate         DateTime? @map("login_date")
  defaultContentType String? @map("default_content_type")
  defaultContentUrl String?  @map("default_content_url")
  linkUrl           String?  @map("link_url")
  location          String?
  region            String?
  kdDealer          String?  @map("kd_dealer")
  lat               Float?
  lng               Float?
  /// Note: DB column is "spesification" (legacy typo). Mapped to correct spelling here.
  specification     Json?    @map("spesification")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  takePictures      TakePicture[]

  @@index([status])
  @@map("hardware_activations")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model TakePicture {
  id         String   @id @default(uuid())
  hardwareId String   @map("hardware_id")
  status     Int      @default(0)
  message    String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  hardware   HardwareActivation @relation(fields: [hardwareId], references: [hardwareId], onDelete: Cascade)

  @@index([hardwareId, createdAt(sort: Desc)])
  @@map("take_pictures")
}
